{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "docker",
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 10,
    "healthchecks": {
      "liveness": {
        "command": ["curl", "-f", "http://localhost:8000/api/health"],
        "interval": 30,
        "timeout": 10,
        "startPeriod": 30,
        "failureThreshold": 3
      }
    }
  }
}
